ASTRA_ENV=development
ASTRA_DB_URL=sqlite+aiosqlite:///./data/astra.db
ASTRA_CHROMA_PATH=./data/chroma_db
ASTRA_DATA_PATH=./data
ASTRA_RECIPES_PATH=./recipes
ASTRA_API_HOST=0.0.0.0
ASTRA_API_PORT=8200
ASTRA_LOG_LEVEL=INFO
ASTRA_AUTONOMY_MODE=supervised

# Inference providers — both run via MLX on local MacBook
ASTRA_LEAD_PROVIDER=mlx
ASTRA_LEAD_MODEL=mlx-community/Meta-Llama-3.1-8B-Instruct-4bit
ASTRA_CODE_PROVIDER=mlx
ASTRA_CODE_MODEL=mlx-community/Qwen2.5-Coder-7B-Instruct-4bit
# Only needed if lead_provider=ollama:
# ASTRA_OLLAMA_BASE_URL=http://mac-mini.local:11434

# Sandbox execution
# Leave ASTRA_SANDBOX_HOST empty to run RL/ml/sklearn missions locally (subprocess).
# REQUIRED (non-empty) for dpo/grpo fine-tune missions — SandboxManager force-dispatches
# those task types to this host via SSH and hard-fails (no local fallback) if unset.
# Does NOT change where RL missions run — _detect_backend() ignores this setting
# for other task types (see docs/IMPLEMENT.md Phase 25).
ASTRA_SANDBOX_HOST=
# ASTRA_SANDBOX_HOST=mac-mini.local
# Python executable used to launch the wrapper script on the sandbox host.
# For dpo/grpo the wrapper only needs stdlib (subprocess/sys/os — no requests),
# so plain system python3 on the remote host is enough; do NOT point this at
# this machine's own .venv path, it won't exist on a remote host.
# ASTRA_SANDBOX_PYTHON=/usr/bin/python3
ASTRA_SANDBOX_DATA_PATH=/tmp/astra
# Only needed for SSH sandbox: hostname training scripts use to POST telemetry back
# Set to your MacBook's mDNS name (run: scutil --get LocalHostName)
# ASTRA_TELEMETRY_HOST=your-macbook.local
