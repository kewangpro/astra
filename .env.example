ASTRA_ENV=development
ASTRA_DB_URL=sqlite+aiosqlite:///./data/astra.db
ASTRA_CHROMA_PATH=./data/chroma_db
ASTRA_DATA_PATH=./data
ASTRA_RECIPES_PATH=./recipes
ASTRA_API_HOST=0.0.0.0
ASTRA_API_PORT=8200
ASTRA_LOG_LEVEL=INFO
ASTRA_AUTONOMY_MODE=supervised

# Inference providers
# Lead agent (planning/pivots) — Ollama on mac-mini
ASTRA_LEAD_PROVIDER=ollama
ASTRA_LEAD_MODEL=llama3.1:8b
ASTRA_OLLAMA_BASE_URL=http://mac-mini.local:11434

# Code/error-fix agent — MLX on local MacBook
ASTRA_CODE_PROVIDER=mlx
ASTRA_CODE_MODEL=mlx-community/DeepSeek-Coder-V2-Lite-Instruct-4bit
